<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="?attr/bgColor"
    android:layout_gravity="center_horizontal"
    android:fitsSystemWindows="true"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:paddingLeft="@dimen/margin_padding_normal"
    android:paddingRight="@dimen/margin_padding_normal"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal"
        android:paddingTop="@dimen/activity_vertical_margin"
        android:paddingBottom="@dimen/activity_vertical_margin"
        android:paddingLeft="@dimen/margin_padding_tiny"
        android:paddingRight="@dimen/margin_padding_tiny">

        <TextView
            android:id="@+id/post_prayer_instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center_horizontal"
            android:textColor="?attr/textColor"
            android:text="@string/post_prayer_instructions"
            android:padding="@dimen/margin_padding_normal"
            android:textSize="@dimen/text_size_xxnormal"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/post_prayer_title_layout"
            app:counterEnabled="true"
            app:counterMaxLength="200"
            android:layout_marginBottom="@dimen/margin_padding_small"
            app:hintEnabled="true"
            android:hint="@string/prayer_title"
            android:theme="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.MyStyle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.MyStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_prayer_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="30dp"
                android:layout_gravity="center_vertical"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:textColor="?attr/textColor"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/prayer_description_layout"
            android:layout_width="match_parent"
            android:theme="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.MyStyle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.MyStyle"
            app:counterEnabled="true"
            app:counterMaxLength="950"
            app:hintEnabled="true"
            android:hint="@string/prayer_desc_sample"
            android:layout_height="wrap_content">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_text_prayer_desc"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fadingEdge="vertical"
                android:paddingTop="30dp"
                android:minLines="6"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:scrollbars="vertical"/>

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/prayer_category_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_padding_small"
            android:textSize="@dimen/text_size_xxnormal"
            android:textColor="?attr/textColor"
            android:text="@string/issue_category"/>

        <Spinner
            android:id="@+id/edit_text_prayer_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginBottom="@dimen/margin_padding_small"
            android:layout_marginTop="@dimen/margin_padding_small"
            android:textSize="@dimen/text_size_large"
            android:paddingTop="@dimen/margin_padding_normal"
            android:paddingBottom="@dimen/margin_padding_normal"
            android:maxLines="1"
            android:textColor="?attr/textColor"/>

        <TextView
            android:id="@+id/prayer_images"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_padding_small"
            android:textSize="@dimen/text_size_xxnormal"
            android:textColor="?attr/textColor"
            android:text="@string/prayer_images_instructions"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_prayer_images"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingBottom="8dp"/>

        <Button
            android:id="@+id/post_prayer_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/textColor"
            android:layout_marginTop="@dimen/margin_padding_normal"
            app:backgroundTint="?attr/hintTextColor"
            android:textColor="@color/whiteTextColor"
            android:text="@string/post_prayer"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>