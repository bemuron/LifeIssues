<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:id="@+id/content_card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    card_view:cardBackgroundColor="?attr/cardBgColor"
    android:fitsSystemWindows="true"
    android:layout_margin="@dimen/card_margin"
    card_view:cardCornerRadius="@dimen/card_margin">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/pro_details_container"
        android:paddingBottom="@dimen/padding_list_row"
        android:paddingStart="?listPreferredItemPaddingLeft"
        android:paddingEnd="?listPreferredItemPaddingRight"
        android:paddingTop="@dimen/padding_list_row">

        <TextView
            android:id="@+id/content_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/content_icon_container"
            android:textColor="?attr/textColor"
            android:textStyle="bold"
            android:lines="1"
            android:ellipsize="end"
            android:text="@string/issues_list_instructions"
            android:textSize="@dimen/text_size_xxnormal" />

        <TextView
            android:id="@+id/content_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/textColor"
            android:layout_below="@id/content_title"
            android:layout_toEndOf="@id/content_icon_container"
            android:layout_marginTop="@dimen/margin_padding_small"
            android:lines="3"
            android:ellipsize="end"
            android:text="@string/issues_list_instructions"
            android:textSize="@dimen/text_size_xnormal" />

        <RelativeLayout
            android:id="@+id/content_icon_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <RelativeLayout
                android:id="@+id/icon_front"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/content_image_profile"
                    android:scaleType="centerCrop"
                    android:layout_width="60dp"
                    android:layout_height="60dp" />
            </RelativeLayout>

        </RelativeLayout>

        <TextView
            android:id="@+id/content_poster"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/textColor"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:lines="1"
            android:ellipsize="end"
            android:layout_marginTop="@dimen/margin_padding_small"
            android:text="@string/issues_list_instructions"
            android:textSize="@dimen/text_size_xnormal" />

        <TextView
            android:id="@+id/date_posted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/content_poster"
            android:layout_alignBottom="@id/content_poster"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/margin_padding_small"
            android:gravity="end"
            android:textColor="?attr/textColor"
            android:lines="1"
            android:text="10 MAR 2024"
            android:textSize="@dimen/text_size_normal" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>