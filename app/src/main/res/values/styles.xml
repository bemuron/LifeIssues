<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.DarkActionBar.Bridge">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="bgColor">@color/white</item>
        <item name="hintTextColor">@color/text_black</item>
        <!--        Our app's background colour when light mode is on == white-->
        <item name="textColor">@color/text_black</item>
        <!--        Text color is black-->
        <item name="buttonColor">@color/colorAccent</item>
        <item name="cardBgColor">@color/card_bg_color</item>
        <item name="android:textColor">@color/black</item>

    </style>

    <style name="AlertDialogTheme" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>
    </style>

    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
<!--        <item name="android:windowDrawsSystemBarBackgrounds">true</item>-->
<!--        <item name="android:statusBarColor">@android:color/transparent</item>-->
    </style>

    <style name="MySearchViewStyle" parent="Widget.AppCompat.Light.SearchView">
        <item name="suggestionRowLayout">@layout/result</item>
        <item name="android:textColor">@android:color/primary_text_light</item>
    </style>

    <style name="Widget.MaterialComponents.TextInputLayout.OutlinedBox.MyStyle">
        <item name="boxStrokeColor">@color/colorPrimary</item>
        <item name="hintTextColor">@color/secondaryLightColor</item>
        <item name="colorControlActivated">@color/colorPrimaryDark</item>
    </style>

    <style name="myAutoCompleteTextViewStyle" parent="Widget.AppCompat.ListView.DropDown">
        <item name="android:popupBackground">@color/colorPrimary</item>
    </style>

    <style name="mySearchResult" parent="TextAppearance.AppCompat.SearchResult.Title">
        <item name="android:textColor">@color/colorActionBarText</item>
    </style>

    <style name="suggestionsTheme" parent="TextAppearance.AppCompat.Light.SearchResult.Subtitle">
    <item name="android:background">@color/colorPrimary</item>
    <item name="android:textColor">@color/colorActionBarText</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- Flutterwave customized UI appearance -->
    <style name="FlutterwaveCustomTheme" parent="AppTheme">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/secondaryLightColor</item>
        <item name="OTPButtonStyle">@style/myOtpBtnStyle</item>
        <item name="PayButtonStyle">@style/myBtnStyle</item>
        <item name="PinButtonStyle">@style/myPinButtonStyle</item>
        <item name="OTPHeaderStyle">@style/myPinHeaderStyle</item>
        <item name="TabLayoutStyle">@style/myTabLayoutStyle</item>
        <item name="PinHeaderStyle">@style/myPinHeaderStyle</item>
        <item name="PaymentTileStyle">@style/myPaymentTileStyle</item>
        <item name="PaymentTileTextStyle">@style/myPaymentTileTextStyle</item>
        <item name="PaymentTileDividerStyle">@style/myPaymentTileDividerStyle</item>
    </style>

    <style name="myPaymentTileTextStyle">
        <item name="android:textColor">#000000</item>
    </style>

    <style name="myPaymentTileDividerStyle">
        <item name="android:textColor">#4a4a4a</item>
    </style>

    <style name="myPaymentTileStyle">
        <item name="android:background">#99DCDBDB</item>
    </style>

    <style name="myTabLayoutStyle">
        <item name="android:background">#37474f</item>
    </style>

    <style name="myPinButtonStyle" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/black_rounded_corner_button</item>
        <item name="android:textColor">#ffffff</item>
    </style>

    <style name="myOtpBtnStyle" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/black_rounded_corner_button</item>
        <item name="android:textColor">#ffffff</item>
    </style>

    <style name="myBtnStyle" parent="@android:style/Widget.Button">
        <item name="android:background">@drawable/black_rounded_corner_button</item>
        <item name="android:textColor">#ffffff</item>
    </style>

    <style name="myPinHeaderStyle">
        <item name="android:background">#37474f</item>
    </style>

</resources>
